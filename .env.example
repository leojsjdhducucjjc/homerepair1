# Optional local port override
PORT=3000

# Supabase project config for auth + quote request storage
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Initial owner dashboard credentials used to seed the database on first run
DASHBOARD_USERNAME=owner
DASHBOARD_EMAIL=owner@example.com
DASHBOARD_PASSWORD=change-this-password

# Owner session length in hours
SESSION_TTL_HOURS=24

# Optional email notifications for new quote requests
RESEND_API_KEY=your-resend-api-key
QUOTE_NOTIFICATION_TO=owner@example.com
QUOTE_NOTIFICATION_FROM=Jason's Lake Ozarks <quotes@yourdomain.com>
SITE_URL=https://yourdomain.com
