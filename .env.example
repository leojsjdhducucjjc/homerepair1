# Optional local port override
PORT=3000

# Supabase project config for auth + quote request storage
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Initial owner dashboard credentials used to seed the database on first run
DASHBOARD_USERNAME=owner
DASHBOARD_PASSWORD=change-this-password

# Owner session length in hours
SESSION_TTL_HOURS=24
